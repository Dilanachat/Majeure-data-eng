# Configuration de l'environnement
# Copier ce fichier en .env et ajuster si besoin
# En mode docker, les services se parlent via le reseau interne (mysql, mlflow, api)

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
FRONTEND_PORT=8501
# URL de l'API vue depuis le conteneur frontend (resolution DNS Docker)
API_URL=http://api:8000

# Base de donnees (laisser commente en mode docker)
# DB_URL=mysql+pymysql://user:password@mysql:3306/mlproject
